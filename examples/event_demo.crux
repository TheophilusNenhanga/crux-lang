println("SECTION 7: All Available Keys");
println("═══════════════════════════════════════════════════════════════");
println("");

println("Character keys:");
println("  char(\"a\")? -> " + char("a")?.name());
println("  char(\"Z\")? -> " + char("Z")?.name());
println("  char(\"0\")? -> " + char("0")?.name());
