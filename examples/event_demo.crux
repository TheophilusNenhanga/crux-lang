println("  tab() -> " + tab().name());
println("  backspace() -> " + backspace().name());
println("  delete() -> " + delete().name());
println("  escape() -> " + escape().name());
println("");

println("Arrow keys:");
println("  up() -> " + up().name());
println("  down() -> " + down().name());
println("  left() -> " + left().name());
println("  right() -> " + right().name());
println("");

println("Navigation keys:");
println("  home() -> " + home().name());
println("  end() -> " + end().name());
println("  page_up() -> " + page_up().name());
println("  page_down() -> " + page_down().name());
println("");

println("Function keys:");
