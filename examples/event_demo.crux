println("  ctrl(\"z\")? -> " + ctrl("z")?.name());
println("  alt(\"a\")? -> " + alt("a")?.name());
println("  alt(\"f4\")? -> " + alt("f")?.name());

println("");

println("═══════════════════════════════════════════════════════════════");
println("SECTION 8: Event Data Access");
println("═══════════════════════════════════════════════════════════════");
println("");

let data_event = Event("keydown", "demo", {
    "key": char("w")?,
    "shift": false,
    "ctrl": true,
    "alt": false,
    "repeat": false,
    "metadata": "extra info"
});

println("Event created with custom data:");
println("  type(): " + data_event.type());
println("  source(): " + data_event.source());
println("  timestamp(): " + string(data_event.timestamp()));

let retrieved_data = data_event.data();
println("  data()[\"ctrl\"]: " + string(retrieved_data["ctrl"]));
println("  data()[\"metadata\"]: " + string(retrieved_data["metadata"]));

println("");

