use (
    print,
    println,
    print_to,
    println_to,
    scan,
    scanln,
    nscan,
    scan_from,
    scanln_from,
    nscan_from
) from "crux:io";

// testing print()
print("This is a test.");
print(" This should print on the same line.\n");

// testing println()
println("This should add a new line at the end.");
println("This should be on a new line.");

// testing print_to()
print_to("stderr", "This is an error.");
print_to("stdout", "This is not an error.");

// testing println_to()
print_to("stderr", "This is an error with a new line at the end.");
print_to("stdout", "This is not an error with a new line at the end.");

