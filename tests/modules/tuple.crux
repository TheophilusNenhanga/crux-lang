use println from "crux:io";
use Tuple from "crux:tuple";

println("=== Testing basic tuple creation ===");
let t = Tuple([1, 2, 3]);
assert(typeof t == "Tuple", "Failed to create basic tuple");

println("=== Testing tuple with mixed types ===");
let t_mixed = Tuple([1, "hello", true]);
assert(typeof t_mixed == "Tuple", "Failed to create tuple with mixed types");

println("=== Testing is_empty() method ===");
let empty = Tuple([]);
assert(empty.is_empty() == true, "Newly created empty tuple should be empty");
assert(t.is_empty() == false, "Tuple with elements should not be empty");

println("=== Testing len() function ===");
assert(len(t) == 3, "Tuple should have length 3");
assert(len(empty) == 0, "Empty tuple should have length 0");

println("=== Testing get() method ===");
assert(t.get(0)._unwrap() == 1, "get(0) should return 1");
assert(t.get(1)._unwrap() == 2, "get(1) should return 2");
assert(t.get(2)._unwrap() == 3, "get(2) should return 3");

println("=== Testing get() out of bounds ===");
let out_of_bounds_result = t.get(5);
let out_of_bounds = out_of_bounds_result._unwrap();
assert(typeof out_of_bounds == "Error", "get(5) should return Error");

println("=== Testing first() method ===");
assert(t.first()._unwrap() == 1, "first() should return 1");
let first_empty_result = Tuple([]).first();
let first_empty = first_empty_result._unwrap();
assert(typeof first_empty == "Error", "first() on empty tuple should return Error");

println("=== Testing last() method ===");
assert(t.last()._unwrap() == 3, "last() should return 3");
let last_empty_result = Tuple([]).last();
let last_empty = last_empty_result._unwrap();
assert(typeof last_empty == "Error", "last() on empty tuple should return Error");

println("=== Testing contains() method ===");
assert(t.contains(1) == true, "Tuple should contain 1");
assert(t.contains(2) == true, "Tuple should contain 2");
assert(t.contains(3) == true, "Tuple should contain 3");
assert(t.contains(4) == false, "Tuple should not contain 4");
assert(t.contains("hello") == false, "Tuple should not contain 'hello'");

println("=== Testing contains() with mixed types ===");
assert(t_mixed.contains(1) == true, "Tuple should contain 1");
assert(t_mixed.contains("hello") == true, "Tuple should contain 'hello'");
assert(t_mixed.contains(true) == true, "Tuple should contain true");

println("=== Testing index() method ===");
assert(t.index(1)._unwrap() == 0, "index(1) should return 0");
assert(t.index(2)._unwrap() == 1, "index(2) should return 1");
assert(t.index(3)._unwrap() == 2, "index(3) should return 2");
let not_found_result = t.index(100);
let not_found = not_found_result._unwrap();
assert(typeof not_found == "Error", "index(100) should return Error");

println("=== Testing to_array() method ===");
let arr = t.to_array();
assert(typeof arr == "Array", "to_array() should return Array");
assert(len(arr) == 3, "to_array() should have 3 elements");
assert(arr[0] == 1, "to_array()[0] should be 1");
assert(arr[1] == 2, "to_array()[1] should be 2");
assert(arr[2] == 3, "to_array()[2] should be 3");

println("=== Testing slice() method ===");
let sliced = t.slice(0, 2);
assert(typeof sliced == "Array", "slice() should return Array");
assert(len(sliced) == 2, "slice(0, 2) should have 2 elements");
assert(sliced[0] == 1, "slice(0, 2)[0] should be 1");
assert(sliced[1] == 2, "slice(0, 2)[1] should be 2");

println("=== Testing slice() with full range ===");
let full_slice = t.slice(0, 3);
assert(len(full_slice) == 3, "slice(0, 3) should have 3 elements");

println("=== Testing slice() with negative indices ===");
let slice_neg = t.slice(1, 3);
assert(len(slice_neg) == 2, "slice(1, 3) should have 2 elements");
assert(slice_neg[0] == 2, "slice(1, 3)[0] should be 2");
assert(slice_neg[1] == 3, "slice(1, 3)[1] should be 3");

println("=== Testing equals() method ===");
let t2 = Tuple([1, 2, 3]);
let t3 = Tuple([1, 2, 4]);
let t4 = Tuple([1, 2]);
assert(t.equals(t2) == true, "Equal tuples should return true");
assert(t.equals(t3) == false, "Different tuples should return false");
assert(t.equals(t4) == false, "Different length tuples should return false");

println("=== Testing empty tuple operations ===");
let empty_t = Tuple([]);
assert(empty_t.is_empty() == true, "Empty tuple should be empty");
assert(len(empty_t) == 0, "Empty tuple should have length 0");
let empty_arr = empty_t.to_array();
assert(len(empty_arr) == 0, "to_array() on empty tuple should return empty array");

println("=== Testing single element tuple ===");
let single = Tuple([42]);
assert(len(single) == 1, "Single element tuple should have length 1");
assert(single.is_empty() == false, "Single element tuple should not be empty");
assert(single.contains(42) == true, "Single element tuple should contain 42");
assert(single.first()._unwrap() == 42, "first() should return 42");
assert(single.last()._unwrap() == 42, "last() should return 42");
assert(single.get(0)._unwrap() == 42, "get(0) should return 42");

println("=== Testing tuple with strings ===");
let str_t = Tuple(["a", "b", "c"]);
assert(str_t.contains("a") == true, "Tuple should contain 'a'");
assert(str_t.contains("b") == true, "Tuple should contain 'b'");
assert(str_t.contains("d") == false, "Tuple should not contain 'd'");
assert(str_t.index("b")._unwrap() == 1, "index('b') should return 1");

println("=== Testing tuple with nested arrays ===");
let nested = Tuple([[1, 2], [3, 4]]);
assert(len(nested) == 2, "Tuple should have 2 elements");
assert(typeof nested.get(0)._unwrap() == "Array", "get(0) should return Array");

println("=== All tuple tests passed ===");
