use println from "crux:io";
use init, exit, size, width, height from "crux:term";

println("=== Testing term module ===");

// Note: Most term functions require a real TTY and will fail in non-interactive environments
// We test that the functions exist and return the expected types

// Test size()
let size_result = size();
assert(typeof size_result == "Result", "size() should return Result");
println("size() returns Result type - PASS");

// Test width()
let width_result = width();
assert(typeof width_result == "Result", "width() should return Result");
println("width() returns Result type - PASS");

// Test height()
let height_result = height();
assert(typeof height_result == "Result", "height() should return Result");
println("height() returns Result type - PASS");

// Test init()
let init_result = init();
assert(typeof init_result == "Result", "init() should return Result");
println("init() returns Result type - PASS");

// Test exit()
let exit_result = exit();
assert(exit_result == nil, "exit() should return nil");
println("exit() returns nil - PASS");

println("=== Term module basic tests completed ===");
