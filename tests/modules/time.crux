use sleep_s, sleep_ms, time_s, time_ms, year, month, day, hour, minute, second, weekday, day_of_year from "crux:time";

println("=== Testing Time Module ===");

// Test _time_s
println("--- Testing _time_s ---");
let _time_s = time_s();
assert(typeof _time_s == "Float", "_time_s should return float");
assert(_time_s > 1700000000.0, "_time_s should return Unix timestamp");
println("_time_s() test passed");

// Test _time_ms
println("--- Testing _time_ms ---");
let _time_ms = time_ms();
assert(typeof _time_ms == "Float", "_time_ms should return float");
assert(_time_ms > 1700000000000.0, "_time_ms should return Unix timestamp in ms");
println("_time_ms() test passed");

// Test _year
println("--- Testing _year ---");
let _year = year();
assert(typeof _year == "Int", "_year should return int");
assert(_year >= 2024 and _year <= 2100, "_year should return reasonable year");
println("_year() test passed");

// Test _month
println("--- Testing _month ---");
let _month = month();
assert(typeof _month == "Int", "_month should return int");
assert(_month >= 1 and _month <= 12, "_month should be 1-12");
println("_month() test passed");

// Test _day
println("--- Testing _day ---");
let _day = day();
assert(typeof _day == "Int", "_day should return int");
assert(_day >= 1 and _day <= 31, "_day should be 1-31");
println("_day() test passed");

// Test _hour
println("--- Testing _hour ---");
let _hour = hour();
assert(typeof _hour == "Int", "_hour should return int");
assert(_hour >= 0 and _hour <= 23, "_hour should be 0-23");
println("_hour() test passed");

// Test _minute
println("--- Testing _minute ---");
let _minute = minute();
assert(typeof _minute == "Int", "_minute should return int");
assert(_minute >= 0 and _minute <= 59, "_minute should be 0-59");
println("_minute() test passed");

// Test _second
println("--- Testing _second ---");
let _second = second();
assert(typeof _second == "Int", "_second should return int");
assert(_second >= 0 and _second <= 59, "_second should be 0-59");
println("_second() test passed");

// Test _weekday
println("--- Testing _weekday ---");
let _weekday = weekday();
assert(typeof _weekday == "Int", "_weekday should return int");
assert(_weekday >= 0 and _weekday <= 7, "_weekday should be 0-7");
println("_weekday() test passed");

// Test _day_of_year
println("--- Testing _day_of_year ---");
let _day_of_year = day_of_year();
assert(typeof _day_of_year == "Int", "_day_of_year should return int");
assert(_day_of_year >= 1 and _day_of_year <= 366, "_day_of_year should be 1-366");
println("_day_of_year() test passed");

// Test sleep_ms (very short sleep)
println("--- Testing sleep_ms ---");
let start = time_ms();
sleep_ms(10)?;
let elapsed = time_ms() - start;
assert(elapsed >= 10, "sleep_ms should sleep at least the specified time");
println("sleep_ms() test passed");

// Test sleep_s (very short sleep)
println("--- Testing sleep_s ---");
let start_s = time_s();
sleep_s(1);
let elapsed_s = time_s() - start_s;
assert(elapsed_s >= 1, "sleep_s should sleep at least the specified time");
println("sleep_s() test passed");

println("=== All Time Module tests passed! ===");
