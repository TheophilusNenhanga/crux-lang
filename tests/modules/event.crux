use println from "crux:io";
use char, enter, tab, backspace, delete, escape from "crux:event";
use up, down, left, right, home, end, page_up, page_down from "crux:event";
use f, ctrl, alt from "crux:event";
use Event from "crux:event";

println("=== Testing Key factory functions ===");

// Test character key
let k_char = char("a")?;
assert(typeof k_char == "Key", "Failed to create character key");
assert(k_char.name() == "a", "Character key name should be 'a'");
assert(k_char.is_char() == true, "Character key should be identified as char");
assert(k_char.is_arrow() == false, "Character key should not be arrow");
assert(k_char.is_function() == false, "Character key should not be function");
assert(k_char.is_modifier() == false, "Character key should not be modifier");
println("Character key tests passed");

// Test Enter key
let k_enter = enter();
assert(k_enter.name() == "Enter", "Enter key name should be 'Enter'");
assert(k_enter.is_char() == false, "Enter key should not be char");
println("Enter key tests passed");

// Test Tab key
let k_tab = tab();
assert(k_tab.name() == "Tab", "Tab key name should be 'Tab'");
println("Tab key tests passed");

// Test Backspace key
let k_backspace = backspace();
assert(k_backspace.name() == "Backspace", "Backspace key name should be 'Backspace'");
println("Backspace key tests passed");

// Test Delete key
let k_delete = delete();
assert(k_delete.name() == "Delete", "Delete key name should be 'Delete'");
println("Delete key tests passed");

// Test Escape key
let k_escape = escape();
assert(k_escape.name() == "Escape", "Escape key name should be 'Escape'");
println("Escape key tests passed");

println("=== Testing Arrow keys ===");

// Test Up arrow
let k_up = up();
assert(k_up.name() == "Up", "Up key name should be 'Up'");
assert(k_up.is_arrow() == true, "Up key should be arrow");
assert(k_up.is_char() == false, "Arrow key should not be char");
println("Up arrow tests passed");

// Test Down arrow
let k_down = down();
assert(k_down.name() == "Down", "Down key name should be 'Down'");
assert(k_down.is_arrow() == true, "Down key should be arrow");
println("Down arrow tests passed");

// Test Left arrow
let k_left = left();
assert(k_left.name() == "Left", "Left key name should be 'Left'");
assert(k_left.is_arrow() == true, "Left key should be arrow");
println("Left arrow tests passed");

// Test Right arrow
let k_right = right();
assert(k_right.name() == "Right", "Right key name should be 'Right'");
assert(k_right.is_arrow() == true, "Right key should be arrow");
println("Right arrow tests passed");

println("=== Testing Navigation keys ===");

// Test Home key
let k_home = home();
assert(k_home.name() == "Home", "Home key name should be 'Home'");
println("Home key tests passed");

// Test End key
let k_end = end();
assert(k_end.name() == "End", "End key name should be 'End'");
println("End key tests passed");

// Test PageUp key
let k_page_up = page_up();
assert(k_page_up.name() == "PageUp", "PageUp key name should be 'PageUp'");
println("PageUp key tests passed");

// Test PageDown key
let k_page_down = page_down();
assert(k_page_down.name() == "PageDown", "PageDown key name should be 'PageDown'");
println("PageDown key tests passed");

println("=== Testing Function keys ===");

// Test F1-F12
let k_f1 = f(1)?;
assert(k_f1.name() == "F1", "F1 key name should be 'F1'");
assert(k_f1.is_function() == true, "F1 should be function key");
assert(k_f1.is_arrow() == false, "Function key should not be arrow");
println("F1 key tests passed");

let k_f5 = f(5)?;
assert(k_f5.name() == "F5", "F5 key name should be 'F5'");
println("F5 key tests passed");

let k_f12 = f(12)?;
assert(k_f12.name() == "F12", "F12 key name should be 'F12'");
println("F12 key tests passed");

println("=== Testing Modifier keys ===");

// Test Ctrl key
let k_ctrl = ctrl("c")?;
assert(k_ctrl.name() == "Ctrl+c", "Ctrl+C name should be 'Ctrl+c'");
assert(k_ctrl.is_modifier() == true, "Ctrl should be modifier");
assert(k_ctrl.is_char() == false, "Modifier should not be char");
println("Ctrl key tests passed");

// Test Alt key
let k_alt = alt("a")?;
assert(k_alt.name() == "Alt+a", "Alt+A name should be 'Alt+a'");
assert(k_alt.is_modifier() == true, "Alt should be modifier");
println("Alt key tests passed");

println("=== Testing Key equals method ===");

// Test equals for same character
let k_a1 = char("a")?;
let k_a2 = char("a")?;
assert(k_a1.equals(k_a2) == true, "Same characters should be equal");
println("Same character equals test passed");

// Test equals for different characters
let k_b = char("b")?;
assert(k_a1.equals(k_b) == false, "Different characters should not be equal");
println("Different character equals test passed");

// Test equals for arrow keys
let k_up1 = up();
let k_up2 = up();
assert(k_up1.equals(k_up2) == true, "Same arrow keys should be equal");
println("Arrow key equals test passed");

// Test equals for different key types
assert(k_a1.equals(k_up1) == false, "Different key types should not be equal");
println("Different key types equals test passed");

println("=== Testing Key char method ===");

// Test char method on character key
let k_x = char("x")?;
let char_result = k_x.char();
assert(char_result != nil, "char() should return value for char key");
println("Character key char() test passed");

// Test char method on non-character key
let k_esc = escape();
let esc_char = k_esc.char();
assert(esc_char == nil, "char() should return nil for non-char key");
println("Non-character key char() test passed");

println("=== Testing Event creation ===");

// Create a basic keydown event
let event_data = {};
let test_key = char("w")?;
event_data["key"] = test_key;
event_data["shift"] = false;
event_data["ctrl"] = false;
event_data["alt"] = false;
event_data["repeat"] = false;

let event = Event("keydown", "test", event_data);
assert(typeof event == "Event", "Event should be of type Event");
println("Event creation test passed");

println("=== Testing Event methods ===");

// Test event type
assert(event.type() == "keydown", "Event type should be 'keydown'");
println("Event type() test passed");

// Test event source
assert(event.source() == "test", "Event source should be 'test'");
println("Event source() test passed");

// Test event timestamp
let ts = event.timestamp();
assert(typeof ts == "Float", "Timestamp should be a float");
assert(ts > 0, "Timestamp should be positive");
println("Event timestamp() test passed");

// Test event data
let data = event.data();
assert(typeof data == "Table", "Event data should be a table");
println("Event data() test passed");

println("=== Testing Event type checking methods ===");

// Test is_keydown
assert(event.is_keydown() == true, "Event should be keydown");
println("Event is_keydown() test passed");

// Test is_key
assert(event.is_key() == true, "Event should be key event");
println("Event is_key() test passed");

// Test is_keyup
assert(event.is_keyup() == false, "Event should not be keyup");
println("Event is_keyup() test passed");

// Test is_mouse
assert(event.is_mouse() == false, "Event should not be mouse event");
println("Event is_mouse() test passed");

// Test is_resize
assert(event.is_resize() == false, "Event should not be resize event");
println("Event is_resize() test passed");

println("=== Testing Event key extraction ===");

let extracted_key = event.key();
assert(extracted_key != nil, "Event should have a key");
assert(extracted_key.name() == "w", "Extracted key should be 'w'");
println("Event key() extraction test passed");

println("=== Testing different event types ===");

// Test keyup event
let keyup_data = {};
keyup_data["key"] = char("q")?;
keyup_data["shift"] = false;
keyup_data["ctrl"] = false;
keyup_data["alt"] = false;
keyup_data["repeat"] = false;

let keyup_event = Event("keyup", "keyboard", keyup_data);
assert(keyup_event.is_keyup() == true, "Event should be keyup");
assert(keyup_event.is_keydown() == false, "Event should not be keydown");
println("Keyup event test passed");

// Test resize event
let resize_data = {};
resize_data["width"] = 80;
resize_data["height"] = 24;

let resize_event = Event("resize", "terminal", resize_data);
assert(resize_event.is_resize() == true, "Event should be resize");
assert(resize_event.is_key() == false, "Resize should not be key event");
let resize_key = resize_event.key();
assert(resize_key == nil, "Resize event should have no key");
println("Resize event test passed");

// Test mousedown event
let mouse_data = {};
mouse_data["x"] = 10;
mouse_data["y"] = 20;
mouse_data["button"] = 1;
mouse_data["shift"] = false;
mouse_data["ctrl"] = false;
mouse_data["alt"] = false;

let mouse_event = Event("mousedown", "mouse", mouse_data);
assert(mouse_event.is_mouse() == true, "Event should be mouse");
assert(mouse_event.is_key() == false, "Mouse should not be key event");
println("Mouse event test passed");

println("=== All Event/Key tests passed! ===");
