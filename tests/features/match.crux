// Testing match keyword

println("=== Testing the match keyword ===");

let m1 = match 2 {
    2 => give "two";
    default => give "not";
};
assert(m1 == "two", "The match keyword did not work as expected");


let m2 = match 3 {
    2 => give "two";
    default => give "not";
};

assert(m2 == "not", "The match keyword did not work as expected");

let m3 = match 3 {
    2 => give "two";
    3 => give "three";
    default => give "not";
};

assert(m3 == "three", "The match keyword did not work as expected");

// NOTE: when matching if no arm matches then the value you are trying to match against is returned.
let m4 = match 4 {
    1 => {
        println("one");
    }
    2 => {
        println("two");
    }
    3 => {
        println("three");
    }
    default => {
        println("unknown");
    }
};

assert(m4 == 4, "Failed to return value from match without give keyword");

match 1 {
    1 => {
        println("one");
    }
    2 => {
        println("two");
    }
    3 => {
        println("three");
    }
    default => {
        println("unknown");
    }
};

let m5;
assert(m5 == nil, "value on stack was not cleared and was assigned to a");

fn test_match() {
    let m6 = match 3 {
        2 => give "two";
        default => give "not";
    };

    return m6;
}

assert(test_match() == "not", "The match keyword did not work in a function");

let m7 = match Ok("test") {
    Ok(value) => {
        give value;
    }
    Err(error) => {
        give error.message();
    }
};

assert(typeof m7 == "String", "match failed to bind value from result matching.");


let m8 = match Err("test") {
    Ok(value) => {
        give value;
    }
    Err(error) => {
        give error;
    }
};

assert(typeof m8 == "Error", "match failed to bind value from result matching.");

let maybe_value: Option[Int] = Some(41);
let nested = match maybe_value {
    Some(value) => give match value + 1 {
        42 => give "forty-two";
        default => give "other";
    };
    None => give "none";
};

assert(nested == "forty-two", "nested match should produce the inner result");

let empty_value: Option[Int] = None;
let option_match = match empty_value {
    Some(value) => give value;
    None => give 0;
};

assert(option_match == 0, "Option match should handle None arms");

let union_value: Int | String = "hello";
let type_match = match union_value {
    Int => give "int";
    String => give "string";
};

assert(type_match == "string", "type match should select the matching union member");

let union_int: Int | String = 99;
let second_type_match = match union_int {
    Int => give "number";
    String => give "text";
};

assert(second_type_match == "number", "type match should match Int union members");


println("=== Completed match keyword test ===");
