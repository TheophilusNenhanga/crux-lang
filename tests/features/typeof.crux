use println from "crux:io";
use Random from "crux:random";

println("=== Testing the type function ===");

let a = "string";
let b = 1;
let c = true;
let d = nil;
let e = [1, 2, 3];
let f = {a: 1, b: 2};
let g = fn (test) { return test; };
struct Test {}
let h = new Test {};
let j = ok("test");
let k = 1.0;
let r = Random();

let aType = typeof a;
let bType = typeof b;
let cType = typeof c;
let dType = typeof d;
let eType = typeof e;
let fType = typeof f;
let gType = typeof g;
let hType = typeof h;
let iType = typeof Test;
let jType = typeof j;
let kType = typeof k;
let rType = typeof r;

assert(aType == "String", "a is not string, got actual: " + aType);
assert(bType == "Int", "b is not an integer, got actual: " + bType);
assert(cType == "Bool", "c is not boolean, got actual: " + cType);
assert(dType == "Nil", "d is not nil, got actual: " + dType);
assert(eType == "Array", "e is not array, got actual: " + eType);
assert(fType == "Table", "f is not table, got actual: " + fType);
assert(gType == "Function", "g is not function, got actual: " + gType);
assert(hType == "Struct instance", "h is not a struct instance, got actual: " + hType);
assert(iType == "Struct", "i is not struct, got actual: " + iType);
assert(jType == "Result", "j is not result, got actual: " + jType);
assert(kType == "Float", "k is not a float, got actual: " + kType);
assert(rType == "Random", "r is not a Random, got actual: " + rType);

println("=== type function test complete ===");
