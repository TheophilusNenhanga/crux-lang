use Random from "crux:random";
use Buffer from "crux:buffer";
use Range from "crux:range";
use Complex from "crux:complex";
use Matrix from "crux:matrix";
use Vector from "crux:vector";

println("=== Testing the type function ===");

let a = nil;
let b = false;
let c = "string";
let d = 12;
let e = 23.43;
let f = [1, 2, 3];
let g = {"a": 1, "b": 2};
let h = fn (test) { return test; };
struct Test {}
let i = new Test {};
let j = Ok("test");
let j2 = Err("test");
let k = Random();
let l = Buffer();
let m = Matrix(2, 2)?;
let n = Vector(4, [1, 2, 3, 4])?;
let o = Complex(1, 2);
let p = Range(0, 2, 10)?;
let q = Some(0);
let r = None;

let aType = typeof a;
let bType = typeof b;
let cType = typeof c;
let dType = typeof d;
let eType = typeof e;
let fType = typeof f;
let gType = typeof g;
let hType = typeof h;
let iType = typeof i;
let jType = typeof j;
let j2Type = typeof j2;
let kType = typeof k;
let lType = typeof l;
let mType = typeof m;
let nType = typeof n;
let oType = typeof o;
let pType = typeof p;
let qType = typeof q;
let rType = typeof r;

println(aType);
println(bType);
println(cType);
println(dType);
println(eType);
println(fType);
println(gType);
println(hType);
println(iType);
println(jType);
println(j2Type);
println(kType);
println(lType);
println(mType);
println(nType);
println(oType);
println(pType);
println(qType);
println(rType);

assert(aType == "Nil", "a is not nil, got actual: " + aType);
assert(bType == "Bool", "b is not boolean, got actual: " + bType);
assert(cType == "String", "c is not string, got actual: " + cType);
assert(dType == "Int", "d is not integer, got actual: " + dType);
assert(eType == "Float", "e is not float, got actual: " + eType);
assert(fType == "Array[Int]", "f is not array, got actual: " + fType);
assert(gType == "Table", "g is not table, got actual: " + gType);
assert(hType == "Function", "h is not function, got actual: " + hType);
assert(iType == "Test instance", "i is not struct instance, got actual: " + iType);
assert(jType == "Result[String]", "j is not result, got actual: " + jType);
assert(j2Type == "Result[Error]", "j2 is not result, got actual: " + j2Type);
assert(kType == "Random", "k is not Random, got actual: " + kType);
assert(qType == "Option[Int]", "q is not Option, got actual: " + qType);
assert(rType == "Option[None]", "r is not Option, got actual: " + rType);
assert(lType == "Buffer", "l is not Buffer, got actual: " + lType);
assert(mType == "Matrix[2, 2]", "m is not Matrix, got actual: " + mType);
assert(nType == "Vector[4]", "n is not Vector, got actual: " + nType);
assert(oType == "Complex", "o is not Complex, got actual: " + oType);
assert(pType == "Range", "p is not Range, got actual: " + pType);
assert(qType == "Option[Int]", "q is not Option, got actual: " + qType);

println("=== type function test complete ===");
