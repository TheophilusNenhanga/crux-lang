use println from "crux:io";
use _time_ms from "crux:time";

fn fib(n: Int) -> Int {
	if n <= 1 return 1;
	return fib(n - 1) + fib(n - 2);
}

fn main() {
	let start_time = _time_ms();
	println(fib(39));
	let end_time = _time_ms();
	println("Time taken:" + string(end_time - start_time) + "ms");
}

main();
